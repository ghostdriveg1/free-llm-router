{
  "manifest_version": 3,
  "name": "Nancy — Free LLM Router",
  "version": "0.1.0",
  "description": "Browser-side relay that converts free chatbot UIs into OpenAI-compatible API endpoints via Nancy HF Space.",
  "minimum_chrome_version": "116",

  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "sidePanel",
    "activeTab",
    "debugger"
  ],

  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://kimi.moonshot.cn/*",
    "https://claude.ai/*"
  ],

  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },

  "side_panel": {
    "default_path": "side-panel/panel.html"
  },

  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": [
        "content-scripts/input-simulator.js",
        "content-scripts/isolated-observer.js"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": [
        "content-scripts/main-interceptor.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "content-scripts/input-simulator.js",
        "content-scripts/isolated-observer.js"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "content-scripts/main-interceptor.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chat.deepseek.com/*"
      ],
      "js": [
        "content-scripts/input-simulator.js",
        "content-scripts/isolated-observer.js"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://chat.deepseek.com/*"
      ],
      "js": [
        "content-scripts/main-interceptor.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://kimi.moonshot.cn/*"
      ],
      "js": [
        "content-scripts/input-simulator.js",
        "content-scripts/isolated-observer.js"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://kimi.moonshot.cn/*"
      ],
      "js": [
        "content-scripts/main-interceptor.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "content-scripts/input-simulator.js",
        "content-scripts/isolated-observer.js"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "content-scripts/main-interceptor.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "Nancy — Open Side Panel"
  }
}
